# Copy to .env.local for local dev, and set the same in Vercel for production.

# Public site origin — drives canonical URLs, OG tags, sitemap, robots.
# The real domain.
NEXT_PUBLIC_SITE_URL=https://sonadesign.pl

# Contact form (Resend). Get a key at https://resend.com
RESEND_API_KEY=

# Inbox that receives enquiries. Defaults to SITE_EMAIL in src/lib/site.ts.
CONTACT_TO_EMAIL=

# Verified Resend sender. Before verifying your domain in Resend, use:
#   Sona <onboarding@resend.dev>   (delivers only to the Resend account owner)
# After verifying sonadesign.pl in Resend, switch to:
#   Sona <kontakt@sonadesign.pl>
CONTACT_FROM_EMAIL=
